# Go - github/gitignore Go.gitignore

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/orrery

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env

# Local build output
/dist/

# Embedded dashboard build: no build output in git. The committed .gitkeep is
# what the go:embed pattern matches before `task dashboard` has ever run.
internal/api/webui/dist/*
!internal/api/webui/dist/.gitkeep
